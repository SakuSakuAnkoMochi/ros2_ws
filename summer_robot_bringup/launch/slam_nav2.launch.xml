<?xml version='1.0' encoding='utf-8'?>
<launch>
    <arg name="use_sim_time" default="true" />
    <node pkg="rviz2" exec="rviz2" name="rviz2" args="-d /home/ubuntu/ros2_ws/src/ros2_ws/ros2_tmp.rviz" output="screen">
        <param name="use_sim_time" value="$(var use_sim_time)" />
    </node>
    <include file="$(find-pkg-share slam_toolbox)/launch/online_async_launch.py">
        <arg name="params_file" value="$(find-pkg-share summer_robot_slam)/config/slam_toolbox_params.yaml" />
        <arg name="use_sim_time" value="true" />
    </include>
    <include file="$(find-pkg-share nav2_bringup)/launch/bringup_launch.py">
        <arg name="use_sim_time" value="true" />
        <arg name="slam" value="True"/>
        <arg name="use_localization" value="False"/>
        <arg name="params_file" value="$(find-pkg-share summer_robot_nav2)/config/nav2_params.yaml" />
    </include>
</launch>