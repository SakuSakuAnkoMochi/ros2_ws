<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="omni_robot">

<!-- 慣性モーメント自動計算用マクロの定義 -->
<!-- ボックス（直方体）用 -->
<xacro:macro name="box_inertial" params="mass x y z *origin">
  <inertial>
    <xacro:insert_block name="origin"/>
    <mass value="${mass}"/>
    <inertia ixx="${mass*(y*y+z*z)/12}" ixy="0" ixz="0"
             iyy="${mass*(x*x+z*z)/12}" iyz="0"
             izz="${mass*(x*x+y*y)/12}"/>
  </inertial>
</xacro:macro>

<!-- シリンダ（円柱）用 -->
<xacro:macro name="cylinder_inertial" params="mass r h *origin">
  <inertial>
    <xacro:insert_block name="origin"/>
    <mass value="${mass}"/>
    <inertia ixx="${mass*(3*r*r+h*h)/12}" ixy="0" ixz="0"
             iyy="${mass*(3*r*r+h*h)/12}" iyz="0"
             izz="${mass*r*r/2}"/>
  </inertial>
</xacro:macro>

<xacro:property name="robot_size" value="0.7" />

<link name="base_footprint"/>

<link name="base_link">
    <visual>
        <geometry>
            <box size="${robot_size} ${robot_size} 0.015"/>
        </geometry>
    </visual>
    <collision>
        <geometry>
            <box size="${robot_size} ${robot_size} 0.015"/>
        </geometry>
    </collision>
    <xacro:box_inertial mass="5.0" x="${robot_size}" y="${robot_size}" z="0.015">
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:box_inertial>
</link>

<joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
</joint>

<xacro:macro name="wheel" params="prefix angle">
<link name="${prefix}">
    <visual>
        <geometry>
            <cylinder length="0.02" radius="0.05"/>
        </geometry>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.02" radius="0.05"/>
        </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.1" r="0.05" h="0.02">
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:cylinder_inertial>
</link>

<!-- オムニホイールの滑り表現用の摩擦設定 -->
<gazebo reference="${prefix}">
    <mu1>1.0</mu1>
    <mu2>0.0</mu2>
    <fdir1>1 0 0</fdir1>
</gazebo>

<joint name="${prefix}_joint" type="continuous">
    <parent link="base_link"/>
    <child link="${prefix}"/>
    <origin rpy="${pi/2} 0 ${pi/2+angle}" xyz="${robot_size/2*1.41421356*cos(angle)} ${robot_size/2*1.41421356*sin(angle)} 0" />
    <axis xyz="0 0 1" />
</joint>

<ros2_control name="${prefix}_shaft_trans" type="system">
  <hardware>
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>
  <joint name="${prefix}_joint">
    <command_interface name="velocity"/>
    <state_interface name="position" />
    <state_interface name="velocity" />
  </joint>
</ros2_control>
</xacro:macro>

<xacro:wheel prefix="wheel0_motor_shaft" angle="${pi/4}"/>
<xacro:wheel prefix="wheel1_motor_shaft" angle="${3*pi/4}"/>
<xacro:wheel prefix="wheel2_motor_shaft" angle="${5*pi/4}"/>
<xacro:wheel prefix="wheel3_motor_shaft" angle="${7*pi/4}"/>

<link name="lidar_link">
    <visual>
        <geometry>
            <cylinder length="0.05" radius="0.05"/>
        </geometry>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.05" radius="0.05"/>
        </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.1" r="0.05" h="0.05">
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:cylinder_inertial>
</link>

<joint name="lidar_link_joint" type="continuous">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.02" />
    <axis xyz="0 0 1" />
</joint>

<xacro:macro name="arm" params="prefix xyz rpy">
<link name="${prefix}_base_link">
    <visual>
        <geometry>
            <box size="0.1 0.1 0.5"/>
        </geometry>
    </visual>
</link>

<joint name="${prefix}_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="${prefix}_base_link"/>
    <origin rpy="${rpy}" xyz="${xyz}" />
</joint>

<xacro:property name="arm_link_length" value="0.3" />
<link name="${prefix}_link">
    <visual>
        <origin rpy="0 0 0" xyz="0 ${arm_link_length/2} 0" />
        <geometry>
            <box size="0.1 ${arm_link_length} 0.1"/>
        </geometry>
    </visual>
    <collision>
        <origin rpy="0 0 0" xyz="0 ${arm_link_length/2} 0" />
        <geometry>
            <box size="0.1 ${arm_link_length} 0.1"/>
        </geometry>
    </collision>
    <xacro:box_inertial mass="0.5" x="0.1" y="${arm_link_length}" z="0.1">
        <origin rpy="0 0 0" xyz="0 ${arm_link_length/2} 0" />
    </xacro:box_inertial>
</link>

<joint name="${prefix}_joint" type="revolute">
    <parent link="${prefix}_base_link"/>
    <child link="${prefix}_link"/>
    <origin rpy="0 0 0" xyz="0 0 0" />
    <axis xyz="1 0 0" />
    <limit effort="1000.0" lower="-0.7" upper="0.7" velocity="0.5"/>
</joint>

<xacro:property name="arm_link2_length" value="0.2" />
<link name="${prefix}_link2">
    <visual>
        <origin rpy="0 0 0" xyz="0 ${arm_link2_length/2} 0" />
        <geometry>
            <box size="0.1 ${arm_link2_length} 0.1"/>
        </geometry>
    </visual>
    <collision>
        <origin rpy="0 0 0" xyz="0 ${arm_link2_length/2} 0" />
        <geometry>
            <box size="0.1 ${arm_link2_length} 0.1"/>
        </geometry>
    </collision>
    <xacro:box_inertial mass="0.3" x="0.1" y="${arm_link2_length}" z="0.1">
        <origin rpy="0 0 0" xyz="0 ${arm_link2_length/2} 0" />
    </xacro:box_inertial>
</link>

<joint name="${prefix}_joint2" type="revolute">
    <parent link="${prefix}_link"/>
    <child link="${prefix}_link2"/>
    <origin rpy="0 0 0" xyz="0 ${arm_link_length} 0" />
    <axis xyz="1 0 0" />
    <limit effort="1000.0" lower="-0.7" upper="0.7" velocity="0.5"/>
</joint>
</xacro:macro>

<xacro:arm prefix="arm1" xyz="0 0.3 0.25" rpy="0 0 0"/>
<xacro:arm prefix="arm2" xyz="0.2 0.3 0.25" rpy="0 0 0"/>
<xacro:arm prefix="arm3" xyz="-0.2 0.3 0.25" rpy="0 0 0"/>
<xacro:arm prefix="arm4" xyz="0 -0.3 0.25" rpy="0 0 ${pi}"/>
<xacro:arm prefix="arm5" xyz="0.2 -0.3 0.25" rpy="0 0 ${pi}"/>
<xacro:arm prefix="arm6" xyz="-0.2 -0.3 0.25" rpy="0 0 ${pi}"/>

<link name="camera_link">
    <visual>
        <geometry>
            <box size="0.1 0.1 0.1"/>
        </geometry>
    </visual>
</link>

<joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin rpy="${-pi/4} 0 0" xyz="0 0.3 0.75" />
</joint>

<link name="camera_link2">
    <visual>
        <geometry>
            <box size="0.1 0.1 0.1"/>
        </geometry>
    </visual>
</link>

<joint name="camera_joint2" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link2"/>
    <origin rpy="${-pi/4} 0 ${pi}" xyz="0 -0.3 0.75" />
</joint>


<xacro:macro name="gather" params="prefix xyz">
<link name="${prefix}_base_link">
    <visual>
        <geometry>
            <box size="0.1 0.1 0.5"/>
        </geometry>
    </visual>
</link>

<joint name="${prefix}_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="${prefix}_base_link"/>
    <origin rpy="0 0 0" xyz="${xyz}" />
</joint>

<link name="${prefix}_link">
    <visual>
        <geometry>
            <box size="0.3 0.1 0.1"/>
        </geometry>
    </visual>
    <collision>
        <geometry>
            <box size="0.3 0.1 0.1"/>
        </geometry>
    </collision>
    <xacro:box_inertial mass="0.3" x="0.3" y="0.1" z="0.1">
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:box_inertial>
</link>

<joint name="${prefix}_joint" type="prismatic">
    <parent link="${prefix}_base_link"/>
    <child link="${prefix}_link"/>
    <origin rpy="0 0 0" xyz="0.2 0 0" />
    <axis xyz="0 0 1" />
    <limit effort="1000.0" lower="-0.2" upper="0.2" velocity="0.5"/>
</joint>
</xacro:macro>

<xacro:gather prefix="gather1" xyz="0.3 0.1 0.25"/>
<xacro:gather prefix="gather2" xyz="0.3 -0.1 0.25"/>

<link name="camera_link3">
    <visual>
        <geometry>
            <box size="0.1 0.1 0.1"/>
        </geometry>
    </visual>
</link>

<joint name="camera_joint3" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link3"/>
    <origin rpy="${-pi/4} 0 ${-pi/2}" xyz="0.3 0 0.75" />
</joint>
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <robotNamespace>/odm_robot</robotNamespace>
      <parameters>$(find summer_robot_ros2_control)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>
</robot>