<?xml version='1.0' encoding='utf-8'?>
<launch>
    <arg name="use_sim_time" default="false" />
    <node pkg="tf2_ros" exec="static_transform_publisher" name="world_to_field_publisher" args="0 0 0 0 0 0 map base_link" >
        <param name="use_sim_time" value="$(var use_sim_time)" />
    </node>
    <node pkg="interactive_waypoint" exec="waypoint_node" name="waypoint_node" output="screen">
        <param name="use_sim_time" value="$(var use_sim_time)" />
    </node>
    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen">
        <param name="use_sim_time" value="$(var use_sim_time)" />
    </node>
</launch>